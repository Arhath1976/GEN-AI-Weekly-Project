<?xml version='1.0' encoding='utf-8'?>
<graphml xmlns="http://graphml.graphdrawing.org/xmlns" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://graphml.graphdrawing.org/xmlns http://graphml.graphdrawing.org/xmlns/1.0/graphml.xsd">
  <key id="d2" for="edge" attr.name="evidence" attr.type="string" />
  <key id="d1" for="edge" attr.name="predicate" attr.type="string" />
  <key id="d0" for="node" attr.name="label" attr.type="string" />
  <graph edgedefault="directed">
    <node id="ACME">
      <data key="d0">ACME</data>
    </node>
    <node id="enterprise search">
      <data key="d0">enterprise search</data>
    </node>
    <node id="BetaLabs">
      <data key="d0">BetaLabs</data>
    </node>
    <node id="legal research">
      <data key="d0">legal research</data>
    </node>
    <node id="The retrieval system">
      <data key="d0">The retrieval system</data>
    </node>
    <node id="None">
      <data key="d0">None</data>
    </node>
    <edge source="ACME" target="enterprise search" id="0">
      <data key="d1">builds AI tools for</data>
      <data key="d2">ACME builds AI tools for enterprise search.</data>
    </edge>
    <edge source="ACME" target="BetaLabs" id="0">
      <data key="d1">acquired</data>
      <data key="d2">ACME acquired BetaLabs in 2024.</data>
    </edge>
    <edge source="BetaLabs" target="legal research" id="0">
      <data key="d1">developed a retrieval system for</data>
      <data key="d2">BetaLabs developed a retrieval system for legal research.</data>
    </edge>
    <edge source="The retrieval system" target="None" id="0">
      <data key="d1">uses embeddings and vector search</data>
      <data key="d2">The retrieval system uses embeddings and vector search.</data>
    </edge>
  </graph>
</graphml>
